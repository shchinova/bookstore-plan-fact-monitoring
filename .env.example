# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env      (Mac/Linux)
#   copy .env.example .env    (Windows)
#
# Файл .env добавлен в .gitignore и не попадает в репозиторий.
# Файл .env.example — попадает, это инструкция для других пользователей.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookstore_ods
DB_USER=postgres
DB_PASSWORD=